# ---- Yosh Iste'dodlar Kompasi — environment -----------------------------
# Copy to .env and fill in. NEVER commit .env.

# --- Core ---
NODE_ENV=production
APP_PORT=8080
# Absolute origin the app is served from (used to build report links for
# SMS/Telegram delivery). e.g. https://kompas.example.uz
PUBLIC_BASE_URL=

# --- Postgres (compose provisions this DB) ---
POSTGRES_USER=yik
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=yik
# For a managed/external DB instead, set DATABASE_URL directly and drop the db
# service from docker-compose.yml:
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Override per your account access. Spec suggests Sonnet to start; a Haiku tier
# (e.g. claude-haiku-4-5-20251001) cuts cost if Uzbek quality holds up.
ANTHROPIC_MODEL=claude-sonnet-4-5
# CONVERSATION_MAX_TOKENS=1500
# REPORT_MAX_TOKENS=3000

# --- Admin auth ---
# Long random string (>=32 chars). Generate: openssl rand -base64 48
JWT_SECRET=
ADMIN_EMAIL=admin@markaz.uz
ADMIN_PASSWORD=change-me-strong
# Set false only for local http testing.
COOKIE_SECURE=true

# --- Report delivery ---
# console (default; logs the link) | telegram
DELIVERY_PROVIDER=console
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Optional shared secret; set the same value when registering the webhook.
TELEGRAM_WEBHOOK_SECRET=

# --- Consent bookkeeping ---
CONSENT_TEXT_VERSION=uz-2026-07

# --- Caps / rate limits (defaults shown) ---
# MAX_TURNS=60
# MAX_MESSAGE_CHARS=2000
# RL_MESSAGES_PER_MIN=20
# RL_SESSIONS_PER_DAY=5
# RL_ADMIN_LOGIN_PER_MIN=5
