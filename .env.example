# ---- Yosh Iste'dodlar Kompasi — environment -----------------------------
# Copy to .env and fill in. NEVER commit .env.

# --- Core ---
NODE_ENV=production
APP_PORT=8080
# Absolute origin the app is served from (used to build report links for
# SMS/Telegram delivery). e.g. https://kompas.example.uz
PUBLIC_BASE_URL=

# --- Production TLS (make prod-up: nginx terminates HTTPS) ---
# Your domain (DNS A-record pointing at this server). One-time cert issuance:
#   make cert DOMAIN=kompas.example.uz EMAIL=you@example.com
# then set DOMAIN here and `make prod-up`. Renewal is automatic (certbot
# sidecar + nginx reload).
DOMAIN=
# Where certificates live on the host (default ./letsencrypt):
# LETSENCRYPT_DIR=./letsencrypt
# Nightly backups (in-stack cron) land in ./backups, pruned after:
# BACKUP_KEEP_DAYS=14

# --- Postgres (compose provisions this DB) ---
POSTGRES_USER=yik
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=yik
# For a managed/external DB instead, set DATABASE_URL directly and drop the db
# service from docker-compose.yml:
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# --- LLM provider ---
# Which backend the Claude proxy talks to:
#   anthropic  = Anthropic Messages API directly (needs ANTHROPIC_API_KEY)
#   openrouter = OpenRouter (OpenAI-compatible; needs OPENROUTER_API_KEY).
# Use openrouter when direct Anthropic API billing is unavailable (e.g. a card
# the Anthropic Console rejects) — OpenRouter can still route to a Claude model.
LLM_PROVIDER=anthropic

# --- Claude / Anthropic (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
# Spec §4: start with claude-sonnet-4-6; A/B claude-haiku-4-5-20251001 to cut
# cost if Uzbek quality holds up. Must match a model your account can call.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenRouter (used when LLM_PROVIDER=openrouter) ---
# Get a key at https://openrouter.ai/keys and add credits to your account.
OPENROUTER_API_KEY=sk-or-...
# Model slug from https://openrouter.ai/models. NOTE: OpenRouter uses namespaced
# vendor/model slugs with DOT versions (anthropic/claude-sonnet-4.6) — the bare
# Anthropic id (claude-sonnet-4-6) is NOT valid on OpenRouter and will be
# rejected. The prompt is tuned for Claude, so an anthropic/* slug behaves
# closest to the direct path.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
# Optional attribution shown on your OpenRouter dashboard (defaults derive from
# PUBLIC_BASE_URL / app name):
# OPENROUTER_SITE_URL=https://kompas.example.uz
# OPENROUTER_SITE_NAME=Yoshlar Kompasi

# Shared generation budgets (apply to whichever provider is active):
# CONVERSATION_MAX_TOKENS=1500
# REPORT_MAX_TOKENS=4500
# The full report is one long non-streaming generation (often 1-3 minutes).
# If you put a reverse proxy in front, its read timeout must be >= this.
# REPORT_TIMEOUT_MS=180000

# --- Cost tracking (admin panel Statistika -> LLM xarajati) ---
# USD per 1M tokens of the ACTIVE model (defaults = claude-sonnet-4.6 list
# prices). Used only for the on-screen estimate; caching discounts not counted.
# PRICE_INPUT_PER_MTOK=3
# PRICE_OUTPUT_PER_MTOK=15
# `make billing-check` alerts (non-zero exit) below this remaining balance:
# BILLING_ALERT_MIN_USD=5

# --- Admin auth ---
# Long random string (>=32 chars). Generate: openssl rand -base64 48
JWT_SECRET=
ADMIN_EMAIL=admin@markaz.uz
ADMIN_PASSWORD=change-me-strong
# Set false only for local http testing.
COOKIE_SECURE=true

# --- Report delivery ---
# console (default; logs the link) | telegram
DELIVERY_PROVIDER=console
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Optional shared secret; set the same value when registering the webhook.
TELEGRAM_WEBHOOK_SECRET=

# --- Consent bookkeeping ---
CONSENT_TEXT_VERSION=uz-2026-07

# --- Data retention (spec §7) ---
# `make purge` deletes data with no session activity for this many months.
RETENTION_MONTHS=24

# --- Caps / rate limits (defaults shown) ---
# MAX_TURNS=60
# MAX_MESSAGE_CHARS=2000
# Real (non-meta) answers required before a report can be generated (floored at 1):
# MIN_ANSWERS_FOR_REPORT=1
# RL_MESSAGES_PER_MIN=20
# RL_SESSIONS_PER_DAY=5
# RL_ADMIN_LOGIN_PER_MIN=5
